[
  {
    "id": "poem",
    "type": "W",
    "fields": {
      "title": "题目。组诗分开整理，标明（作者其x）；不要现当代的，不要小说人物的。",
      "otherNames": "其他题目",
      "author": "作者通用名(有争议的在创作背景中说明)",
      "origin": "古籍优先"
    },
    "content": "体例。\n韵部。\n正文。\n注释。\n注释原则。\n通假。\n注音。\n人物。\n引用。\n用典。\n多种解释。\n多种版本。\n编辑注释。",
    "annotations": [
      {
        "start": 0,
        "end": 2,
        "text": "体例",
        "note": "分类和子类务必明晰，仿xx视作xx。"
      },
      {
        "start": 4,
        "end": 6,
        "text": "韵部",
        "note": "诗根据平水韵，词根据词林正韵，散曲根据中原音韵。多次换韵可不写，少量换韵可注明。"
      },
      {
        "start": 8,
        "end": 10,
        "text": "正文",
        "note": "适当换行，行尾要有标点。"
      },
      {
        "start": 12,
        "end": 14,
        "text": "注释",
        "note": "锁定状态下，选中正文或序，输入注释内容，保留后对应正文会变色（编辑状态下不可见），注释重叠会加深颜色。注释列表会按位置自动排序。"
      },
      {
        "start": 16,
        "end": 20,
        "text": "注释原则",
        "note": "注释力求精简准确，简单的无需注释。原义简单的可以只写引申义，以“指xx”的格式。词曲牌、年号无需注释。除了背景或典故以外，不可整句注释。如注释词和其中单字，需分开注释。"
      },
      {
        "start": 22,
        "end": 24,
        "text": "通假",
        "note": "以“通xx”的格式。"
      },
      {
        "start": 26,
        "end": 28,
        "text": "注音",
        "note": "单字直接注；多字如全注直接注，只注部分以“字音”的格式，叠字按单字注。"
      },
      {
        "start": 30,
        "end": 32,
        "text": "人物",
        "note": "直接点明，如有难度可适当补充解释。"
      },
      {
        "start": 34,
        "end": 36,
        "text": "引用",
        "note": "出自作者《作品》：原文。化用可以没有原文。作者无需朝代。"
      },
      {
        "start": 38,
        "end": 40,
        "text": "用典",
        "note": "以“用xxx之典”的格式，生僻典故可简要说明。"
      },
      {
        "start": 42,
        "end": 46,
        "text": "多种解释",
        "note": "存在多种解释时，使用“一说xx”进行区别。"
      },
      {
        "start": 48,
        "end": 52,
        "text": "多种版本",
        "note": "原文存在多种版本时，使用通用取信版本，注释中用“一作xx”进行说明。"
      },
      {
        "start": 54,
        "end": 58,
        "text": "编辑注释",
        "note": "同一时间只能启用一个注释框，编辑后需保留。点击注释列表中的编辑按钮，或左键原文对应部分，可打开对应的注释框修改注释内容。右键原文对应部分将删除该注释。修改原文不会造成注释位置偏离，如改动涉及注释内容，会自动删除对应注释。"
      }
    ],
    "extra": {
      "preface": "统计时长时，序不计字数。",
      "translation": "简洁准确，与注释务必一致。",
      "background": "简洁准确。作品创作的背景，而非作者背景。",
      "evaluation": [
        {
          "出处": "评价者《评价集》卷x",
          "内容": "评价内容。"
        },
        {
          "出处": "选取",
          "内容": "聚焦古代评价，近现代评价只要公认大师的。评价当前作品，而非作者。"
        },
        {
          "出处": "评价者",
          "内容": "尽量精确信息，如难以确定，可空置部分。禁止标注朝代。针对多人合著的评价集，可明确是谁评价的明确标注，不能的标注作者。"
        },
        {
          "出处": "引注",
          "内容": "能找到原出处的不要引注，不能的在评价内容中注明援引。"
        },
        {
          "出处": "评价内容",
          "内容": "禁止使用双引号包裹全文。"
        }
      ]
    }
  },
